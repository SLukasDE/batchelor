    '+' (43) 14 22
    '-' (45) 15
    '/' (47) 18
    ':' (58) 5 6 8 9 10 11 12 13
    ';' (59) 7 8 9 10 11 12 13
    '{' (123) 4 5 6
    '}' (125) 4 5 6
    error (256)
    IDENTIFIER <std::string> (258) 5 6
    IDENTIFIER_PROC (259) 4 5 6
    IDENTIFIER_VAR (260) 7 8 9 10 11 12 13
    NUMBER <double> (261) 20
    STRING <std::string> (262) 5 7 8 10 12 24
    IDENTIFIER_AND (263) 28
    IDENTIFIER_OR (264) 26
    IDENTIFIER_TRUE (265) 32
    IDENTIFIER_FALSE (266) 33


